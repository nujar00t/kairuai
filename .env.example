# ─── KairuAI · .env.example ─────────────────────────────────
# Copy this file to .env and fill in your keys
# cp .env.example .env

# Anthropic — Prediction + Signal agents
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Solana — Trading agent
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_PRIVATE_KEY=your_base58_private_key_here

# Polymarket — Polymarket agent
POLYMARKET_API_KEY=your_polymarket_api_key
POLYMARKET_SECRET=your_polymarket_secret
POLYMARKET_PASSPHRASE=your_polymarket_passphrase

# Twitter/X — Signal agent (sentiment)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# Optional
HELIUS_API_KEY=your_helius_api_key
DEFAULT_SLIPPAGE_BPS=50
